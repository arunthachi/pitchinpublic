# Supabase Configuration
# Get these from your Supabase project settings (https://app.supabase.com)
NEXT_PUBLIC_APP_URL=https://app.pitchinpublic.io
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Server-only. Optional for lead notification status updates; never expose publicly.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Server-only. Comma-separated emergency/manual access list for the invite-only pilot.
# Event founder invites and organizer invites are also accepted automatically.
PILOT_ALLOWLIST_EMAILS=arun@pitchinpublic.io

# Optional Analytics
# Leave blank to disable Google Tag Manager.
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Lead capture and email nudges
# Used by /api/leads now and reusable for daily pitch prompt emails later.
RESEND_API_KEY=re_xxxxxxxxx
LEAD_EMAIL_FROM=Pitch in Public <hello@mail.pitchinpublic.io>
LEAD_EMAIL_TO=hello@pitchinpublic.io,arun@pitchinpublic.io
# Cron endpoint for automated founder nudges.
CRON_SECRET=replace-with-a-long-random-secret

# Instructions for Supabase Setup:
# 1. Create a Supabase project at https://app.supabase.com
# 2. Go to Settings > API
# 3. Copy the Project URL and anon/public key
# 4. Enable Phone provider in Authentication > Providers for SMS OTP
# 5. Enable Google and LinkedIn OIDC providers for desktop sign in
# 6. Add your site URL in Authentication > URL Configuration

# Video Provider Configuration
# Options: cloudflare, mux, bunny (only cloudflare implemented currently)
VIDEO_PROVIDER=cloudflare

# Cloudflare Stream Configuration
# Get these from: https://dash.cloudflare.com/ -> Stream -> API Tokens
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_STREAM_API_TOKEN=your_api_token_here

# Optional: Cloudflare Stream signing key (for private videos)
# CLOUDFLARE_STREAM_SIGNING_KEY=your_signing_key_here
